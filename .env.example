# Kaza — environment configuration.
# Copy to `.env` and adjust. All variables are optional except SECRET_KEY in
# production (where it should be set explicitly rather than auto-generated).

# Config profile: development | production | testing
KAZA_ENV=development

# HTTP port the app listens on.
PORT=5050

# Directory for the SQLite database and the persisted session secret.
DATA_DIR=./data

# Session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If left empty, a key is generated and persisted under DATA_DIR.
SECRET_KEY=

# PostgreSQL connection URL. Leave empty to use the local SQLite database.
#   e.g. postgresql://user:password@host:5432/kaza
DATABASE_URL=

# Optional: enables AI recipe lookup for dishes not in the built-in cookbook.
# Without it, the built-in Israeli cookbook still works fully offline.
ANTHROPIC_API_KEY=

# Optional: model used for recipe lookup (cheaper/faster: claude-haiku-4-5).
CLAUDE_MODEL=claude-opus-4-8

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Password-reset email (optional) ----------------------------------------
# Without SMTP_HOST, reset links are written to the log instead of emailed, so
# the flow still works in development. Any SMTP provider enables real delivery.
# Gmail example: host smtp.gmail.com, port 587, user = your address, password =
# a Google "App Password" (not your normal password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=1

# Absolute base URL of the deployment, used to build reset links in emails.
#   e.g. https://yonabornstein.pythonanywhere.com
APP_BASE_URL=
